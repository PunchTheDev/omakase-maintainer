# Copy to .env.local (gitignored) and fill in. Load with:  set -a; . ./.env.local; set +a
# Nothing here is ever committed.

# --- worker pool (real models) ---
OPENROUTER_API_KEY=

# --- Hippius S3 weights storage (from console.hippius.com → S3/Access keys) ---
HIPPIUS_ACCESS_KEY=
HIPPIUS_SECRET_KEY=
HIPPIUS_BUCKET=oc-weights

# --- GitHub (maintainer identity for Peggy: comment/label/merge) ---
# Prefer `gh auth login` over a PAT here; only set if running headless.
GH_TOKEN=
