{
 "$comment": "Production config. Swap backends in; no code changes. Secrets via env, never here.",
 "workspace": "..",
 "pool_config": "../omakase-eval/configs/pool.prod.example.json",
 "split": "gate",
 "seed": 1,
 "per_suite": 300,
 "metagraph": {
  "backend": "gittensor-api",
  "api_url": "https://api.gittensor.io",
  "$comment": "validator enforces zero changes to hotkey\u2194github pairing; bind on immutable githubId"
 },
 "storage": {
  "backend": "hippius",
  "bucket": "oc-weights"
 },
 "key_path": "state/maintainer.key",
 "state_db": "state/maintainer.db",
 "repos": {
  "omakase-router": {
   "repo": "<org>/omakase-router",
   "dir": "../omakase-router"
  },
  "omakase-harness": {
   "repo": "<org>/omakase-harness",
   "dir": "../omakase-harness"
  }
 }
}